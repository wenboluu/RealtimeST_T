# Copy to .env and adjust for your machine. scripts/run_server.sh sources this file automatically.

LAB_STT_HOST=127.0.0.1
LAB_STT_PORT=7860
LAB_STT_DEVICE=cuda
LAB_STT_MODEL=small.en
LAB_STT_REALTIME_MODEL=tiny.en
LAB_STT_LANGUAGE=en
LAB_STT_COMPUTE_TYPE=float16
# CPU fallback: set LAB_STT_DEVICE=cpu and LAB_STT_COMPUTE_TYPE=int8.

# Required for first-time pyannote/embedding download if the model is gated for your account.
# Get a token at https://huggingface.co/settings/tokens and accept the model terms first.
HF_TOKEN=

# Calibrated speaker verifier artifacts. The repo includes a tiny LibriSpeech starter
# calibrator at these paths; replace with lab-specific artifacts for production.
LAB_STT_SPEAKER_CALIBRATOR=artifacts/calibration/speaker_calibrator.joblib
LAB_STT_SPEAKER_COHORT_BANK=artifacts/cohorts/cohort_bank.npz
LAB_STT_SPEAKER_PROBABILITY_THRESHOLD=

LAB_STT_SPEAKER_THRESHOLD=0.3
LAB_STT_SPEAKER_MARGIN=0.1
LAB_STT_SPEAKER_WINDOW_SECONDS=3.0
LAB_STT_SPEAKER_MIN_VOICED_SECONDS=0.8

# Optional. Set when binding beyond localhost or using a reverse proxy.
# Browser users can run localStorage.setItem('labSttApiKey', '...') before opening the UI.
LAB_STT_API_KEY=

# Request limits.
LAB_STT_MAX_UPLOAD_MB=100
LAB_STT_MAX_UPLOAD_SECONDS=180
LAB_STT_UPLOAD_DECODE_TIMEOUT=45
LAB_STT_WS_MAX_FRAME_BYTES=256000
LAB_STT_WS_MAX_SESSION_SECONDS=7200
LAB_STT_MAX_SESSIONS=4
