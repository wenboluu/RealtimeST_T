__pycache__/
*.py[cod]
.pytest_cache/
.venv/
.env
.DS_Store

# Local lab data and enrolled voice profiles
data/*.mp3
data/*.wav
data/*.webm
data/speaker_profiles/*
!data/speaker_profiles/.gitkeep
data/datasets/
data/eval/

# Local environment and runtime output
.env.*
!.env.example
*.log
logs/*
!logs/.gitkeep

# Local calibration/model artifacts. Keep the tiny LibriSpeech starter verifier
# versioned so fresh deployments have a baseline speaker calibration.
artifacts/**
!artifacts/
!artifacts/calibration/
!artifacts/calibration/.gitkeep
!artifacts/calibration/speaker_calibrator.joblib
!artifacts/cohorts/
!artifacts/cohorts/.gitkeep
!artifacts/cohorts/cohort_bank.npz
